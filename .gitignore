projects/*/peers/*.conf
!projects/remote-access/awg0.conf
!projects/remote-access/awg1.conf

# pytest
.pytest_cache/
.pytest_cache

# venv
venv311/
.env.infra

# Sensitive data (SSH passwords, API keys)
dontenter/

