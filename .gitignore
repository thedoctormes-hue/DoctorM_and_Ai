# ═══════════════════════════════════════════════════
.qwen/

# ═══════════════════════════════════════════════════
# Проекты — отдельные репозитории (НЕ индексировать)
# ═══════════════════════════════════════════════════
projects/*/
!projects/.gitkeep

# ═══════════════════════════════════════════════════
# Виртуальные окружения
# ═══════════════════════════════════════════════════
venv/
.venv/
.venv-onnx/

