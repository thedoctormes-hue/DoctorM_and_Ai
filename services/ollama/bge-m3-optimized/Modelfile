# BGE-M3 Optimized for CPU-only inference
# Target: AMD EPYC Rome, 4 cores, 8GB RAM
# Optimized for embedding-only workload (no text generation)

FROM bge-m3:latest

# ── Embedding-specific optimizations ──
# num_ctx: 2048 is optimal for our use case (insight texts are short)
# Reducing from 8192 → 2048 cuts attention matrix size by 16x
# (attention_cost ∝ max_length²)
PARAMETER num_ctx 2048

# num_batch: 256 covers our max insight length (~134 tokens)
# Must be >= max input tokens to avoid "input too large" errors
PARAMETER num_batch 256

# num_thread: 3 threads (leave 1 core for system/Ollama overhead)
# Transformer layers are sequential — intra-op parallelism matters most
# 4 threads on 4 cores causes oversubscription under load
PARAMETER num_thread 3

# num_gpu: 0 — force CPU-only (no GPU present)
PARAMETER num_gpu 0

# ── Stability ──
# Keep model loaded in memory (no unloading between requests)
PARAMETER num_keep 0

# ── Template ──
# Minimal template for embedding-only mode
TEMPLATE "{{ .Prompt }}"
