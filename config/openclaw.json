        "safe-restart",
        "change-management",
        "300-vision",
        "colony-disk-exchange",
        "manus-outsourcing"
      ],
      "bootstrapTotalMaxChars": 120000,
      "heartbeat": {
        "isolatedSession": true,
        "lightContext": true
      },
      "contextTokens": 200000,
      "maxConcurrent": 3,
      "thinkingDefault": "low",
      "verboseDefault": "off",
      "reasoningDefault": "off",
      "elevatedDefault": "on",
      "toolProgressDetail": "explain",
      "params": {
        "cacheRetention": "long"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "10m",
        "keepLastAssistants": 4,
        "softTrimRatio": 0.65,
        "hardClearRatio": 0.88,
        "minPrunableToolChars": 1200
