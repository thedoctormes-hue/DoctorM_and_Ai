{
  "messages": {
    "tts": {
      "auto": "off",
      "provider": "microsoft",
      "providers": {
        "microsoft": {
          "enabled": true,
          "speakerVoice": "ru-RU-DmitryNeural",
          "lang": "ru-RU",
          "outputFormat": "audio-24khz-48kbitrate-mono-mp3",
          "rate": "+0%",
          "pitch": "+0%"
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/owl-alpha",
        "fallbacks": [
          "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
          "openrouter/openai/gpt-oss-120b:free",
          "openrouter/nvidia/nemotron-3-ultra-550b-a55b:free"
        ]
      },
      "contextInjection": "continuation-skip",
      "compaction": {
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 30000,
          "model": "openrouter/openai/gpt-oss-120b:free",
          "prompt": "Save decisions, state changes, lessons, blockers, approved actions, and open tasks to memory/YYYY-MM-DD.md. Skip routine conversation. If nothing worth storing: NO_FLUSH",
          "systemPrompt": "Only persist what matters for session continuity. Be concise, no filler."
        },
        "notifyUser": true,
        "postCompactionSections": [
          "AGENTS",
          "SOUL",
          "IDENTITY"
        ],
        "mode": "safeguard",
        "qualityGuard": {
          "enabled": true,
          "maxRetries": 1
        },
        "identifierPolicy": "strict",
        "reserveTokensFloor": 24000,
        "keepRecentTokens": 10000,
        "maxActiveTranscriptBytes": 20971520,
        "model": "cohere/command-r-plus-08-2024",
        "timeoutSeconds": 300
      },
      "contextLimits": {
        "toolResultMaxChars": 32000
      },
      "bootstrapMaxChars": 25000,
      "startupContext": {
        "enabled": true,
        "applyOn": [
          "new",
          "reset"
        ],
        "dailyMemoryDays": 2,
        "maxFileBytes": 16384,
        "maxFileChars": 10000,
        "maxTotalChars": 6000
      },
      "timeoutSeconds": 600,
      "memorySearch": {
        "provider": "ollama",
        "model": "bge-m3",
        "fallback": "none",
        "extraPaths": [
          "/root/LabDoctorM/adr",
          "/root/LabDoctorM/docs",
          "/root/LabDoctorM/specs",
          "/root/LabDoctorM/workspaces/antcat/memory",
          "/root/LabDoctorM/workspaces/mangust/memory",
          "/root/LabDoctorM/workspaces/owl/memory",
          "/root/LabDoctorM/workspaces/raven/memory",
          "/root/LabDoctorM/workspaces/dominika/memory",
          "/root/LabDoctorM/workspaces/kotolizator/memory",
          "/root/LabDoctorM/workspaces/streikbrecher/memory",
          "/root/LabDoctorM/workspaces/bestia/memory",
          "/root/LabDoctorM/projects/DoctorM_and_Ai/docs"
        ],
        "sync": {
          "watch": true
        }
      },
      "skills": [
        "accepting-work",
        "canvas",
        "diagram-maker",
        "finishing-session",
        "gh-issues",
        "github",
        "gitlab",
        "healthcheck",
        "himalaya",
        "labsearch",
        "mcporter",
        "meme-maker",
