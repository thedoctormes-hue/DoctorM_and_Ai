          "summarize",
          "github",
          "healthcheck",
          "gh-issues",
          "nano-pdf",
          "oracle",
          "mcporter"
        ]
      },
      {
        "id": "mangust",
        "name": "mangust",
        "workspace": "/root/LabDoctorM/workspaces/mangust",
        "agentDir": "/root/.openclaw/agents/mangust/agent",
        "tts": {
          "auto": "off",
          "provider": "tts-local-cli",
          "providers": {
            "tts-local-cli": {
              "command": "/root/.openclaw/tools/sherpa-onnx-tts/runtime/bin/sherpa-onnx-offline-tts",
              "args": [
                "--runtime-dir",
                "/root/.openclaw/tools/sherpa-onnx-tts/runtime",
                "--model-dir",
                "/root/.openclaw/tools/sherpa-onnx-tts/models/supertonic-3-ru",
                "--supertonic-duration-predictor",
                "/root/.openclaw/tools/sherpa-onnx-tts/models/supertonic-3-ru/duration_predictor.int8.onnx",
                "--supertonic-text-encoder",
                "/root/.openclaw/tools/sherpa-onnx-tts/models/supertonic-3-ru/text_encoder.int8.onnx",
                "--supertonic-vector-estimator",
                "/root/.openclaw/tools/sherpa-onnx-tts/models/supertonic-3-ru/vector_estimator.int8.onnx",
                "--supertonic-vocoder",
                "/root/.openclaw/tools/sherpa-onnx-tts/models/supertonic-3-ru/vocoder.int8.onnx",
                "--supertonic-tts-json",
                "/root/.openclaw/tools/sherpa-onnx-tts/models/supertonic-3-ru/tts.json",
                "--supertonic-unicode-indexer",
                "/root/.openclaw/tools/sherpa-onnx-tts/models/supertonic-3-ru/unicode_indexer.bin",
                "--supertonic-voice-style",
                "/root/.openclaw/tools/sherpa-onnx-tts/models/supertonic-3-ru/voice.bin",
                "--lang",
                "ru",
                "--num-steps",
                "8",
                "--speed",
                "1.0",
                "--sid",
                "1",
                "--output-filename",
                "{{OutputPath}}",
                "{{Text}}"
              ],
              "outputFormat": "wav",
              "timeoutMs": 120000
            }
          }
        },
