{
  "messages": {
    "tts": {
      "auto": "off",
      "provider": "microsoft",
      "providers": {
        "microsoft": {
          "enabled": true,
          "speakerVoice": "ru-RU-DmitryNeural",
          "lang": "ru-RU",
          "outputFormat": "audio-24khz-48kbitrate-mono-mp3",
          "rate": "+0%",
          "pitch": "+0%"
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/owl-alpha",
        "fallbacks": [
          "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
          "openrouter/openai/gpt-oss-120b:free",
          "openrouter/openai/gpt-oss-20b:free",
          "openrouter/nvidia/nemotron-3-ultra-550b-a55b:free"
        ]
      },
      "contextInjection": "continuation-skip",
      "compaction": {
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 6000,
          "model": "openrouter/openai/gpt-oss-20b:free"
        },
        "notifyUser": true,
        "postCompactionSections": [
          "AGENTS",
          "SOUL",
          "IDENTITY"
        ],
        "mode": "safeguard",
        "qualityGuard": {
          "enabled": true,
          "maxRetries": 1
        },
        "identifierPolicy": "strict"
      },
      "contextLimits": {
        "toolResultMaxChars": 32000
      },
      "bootstrapMaxChars": 25000,
      "startupContext": {
        "enabled": true,
        "applyOn": [
          "new",
          "reset"
        ],
        "dailyMemoryDays": 2,
        "maxFileBytes": 16384,
        "maxFileChars": 10000,
        "maxTotalChars": 6000
      },
      "timeoutSeconds": 600,
      "memorySearch": {
        "provider": "ollama",
        "model": "bge-m3-cpu-512",
        "remote": {
          "baseUrl": "http://127.0.0.1:11434",
          "apiKey": "ollama-local",
          "nonBatchConcurrency": 2
        },
        "fallback": "none",
        "sync": {
          "embeddingBatchTimeoutSeconds": 600
        }
      },
      "skills": [
        "agent-acceptance-protocol",
        "canvas",
        "diagram-maker",
        "gh-issues",
        "git-hygiene",
        "git-lab",
        "github",
        "healthcheck",
        "himalaya",
        "lab-search",
        "meme-maker",
        "node-inspect-debugger",
        "python-debugpy",
        "session-logs",
        "skill-creator",
        "spike",
        "summarize",
        "taskflow",
        "tavily",
        "tmux",
        "video-frames",
        "weather",
        "nano-pdf",
        "oracle",
        "mcporter"
      ],
      "bootstrapTotalMaxChars": 120000,
      "heartbeat": {
        "isolatedSession": true,
        "lightContext": true
      },
      "contextTokens": 200000,
      "maxConcurrent": 3,
      "thinkingDefault": "low",
      "verboseDefault": "off",
      "reasoningDefault": "off",
      "elevatedDefault": "on",
      "toolProgressDetail": "explain",
      "params": {
        "cacheRetention": "long"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      }
    },
    "list": [
      {
        "id": "main",
        "workspace": "/root/.openclaw/workspaces/main",
        "skills": [
          "agent-acceptance-protocol",
          "canvas",
          "diagram-maker",
          "git-hygiene",
          "git-lab",
          "himalaya",
          "lab-search",
          "meme-maker",
